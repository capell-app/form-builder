{
    "manifest-version": 2,
    "name": "capell-app/form-builder",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell FormBuilder",
    "tier": "premium",
    "bundle": "form-builder",
    "description": "FormBuilder adds form definitions, encrypted submissions, frontend Livewire rendering, validation, and submission status handling to Capell.",
    "surfaces": [
        "admin",
        "frontend"
    ],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/admin",
            "capell-app/frontend"
        ],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FormBuilder\\Providers\\FormBuilderServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "assets": [],
    "healthChecks": []
}
