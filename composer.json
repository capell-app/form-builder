{
    "name": "capell-app/form-builder",
    "description": "Build site-scoped forms in Capell and capture spam-filtered, encrypted submissions into a per-site triage inbox with one-click email replies.",
    "keywords": [
        "capell",
        "form-builder",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/form-builder",
    "license": "proprietary",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "capell-app/admin": "^1.0",
        "capell-app/core": "^1.0",
        "capell-app/frontend": "^1.0"
    },
    "suggest": {
        "capell-app/payments": "Enables payment fields and checkout for form submissions."
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\FormBuilder\\": "src/",
            "Capell\\FormBuilder\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\FormBuilder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\FormBuilder\\Providers\\FormBuilderServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "pest"
    },
    "prefer-stable": true,
    "type": "library",
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/form-builder"
    }
}
